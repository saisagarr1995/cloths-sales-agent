# ---- AI brain (free key from https://console.groq.com -> API Keys) ----
GROQ_API_KEY=gsk_your_key_here
# Model served on Groq free tier. Change only if Groq retires this model.
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Business ----
BUSINESS_NAME=Sri Fashions
# UPI ID that receives payments, e.g. 9876543210@okicici or name@ybl
UPI_ID=yourname@upi
# Name shown in the customer's UPI app while paying
UPI_PAYEE_NAME=Sri Fashions
# Free delivery above this amount (rupees). Used by the sales agent as a nudge.
FREE_DELIVERY_ABOVE=999
# Flat delivery charge below that (rupees)
DELIVERY_CHARGE=49

# ---- Owner ----
# WhatsApp number (with country code, digits only) that receives order alerts
# and can confirm payments by replying: confirm ORD123
OWNER_WHATSAPP_NUMBER=919876543210
